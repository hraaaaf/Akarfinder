# AkarFinder — variables d'environnement (copier en .env.local)
# Ne jamais committer .env.local

# ── Fournisseur de base de données ───────────────────────────────────────────
DATABASE_PROVIDER=sqlite

# ── Supabase (requis si DATABASE_PROVIDER=supabase) ──────────────────────────
# Ces deux variables restent SERVEUR UNIQUEMENT — jamais de préfixe NEXT_PUBLIC_.
# Aucune clé anon n'est utilisée : toutes les lectures passent par la service role key.

# URL du projet — Settings > API > Project URL
SUPABASE_URL=https://REMPLACER_PAR_TON_REF.supabase.co

# Clé service role — Settings > API > service_role secret
# Bypass RLS : ne jamais exposer côté client, ne jamais committer.
SUPABASE_SERVICE_ROLE_KEY=REMPLACER_PAR_LA_CLE_SERVICE_ROLE

# ── SQLite local (optionnel) ──────────────────────────────────────────────────
# SQLITE_DB_PATH=scripts/scrapers/output/akarfinder.db
